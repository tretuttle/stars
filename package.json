{
  "name": "@t-rents/stars",
  "version": "1.0.4",
  "description": "Search and discover over your GitHub starred repos. Sync /user/starred, expand via topic search, annotate locally with tags/notes/hidden. Pluggable storage, zero runtime deps, fully typed.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "smoke": "bun scripts/smoke.ts",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tretuttle/stars.git"
  },
  "bugs": {
    "url": "https://github.com/tretuttle/stars/issues"
  },
  "homepage": "https://github.com/tretuttle/stars#readme",
  "author": "Trent Tuttle",
  "license": "MIT",
  "keywords": [
    "github",
    "github-api",
    "github-stars",
    "stars",
    "starred-repos",
    "topics",
    "search",
    "discovery",
    "browser-extension",
    "chrome-extension",
    "typescript",
    "zero-deps",
    "esm"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
